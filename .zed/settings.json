{
  "prettier": {
    "allowed": false
  },
  "languages": {
    "JavaScript": {
      "formatter": {
        "language_server": {
          "name": "eslint"
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TypeScript": {
      "formatter": {
        "language_server": {
          "name": "eslint"
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TSX": {
      "formatter": {
        "language_server": {
          "name": "eslint"
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    }
  }
}
